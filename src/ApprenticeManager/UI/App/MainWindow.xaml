<Window x:Class="ApprenticeManager.UI.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ApprenticeManager.UI.App.Controls"
        Title="Apprentice Manager" Height="680" Width="1100"
        WindowStartupLocation="CenterScreen" MinWidth="800" MinHeight="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#1e3a5f" Padding="15,10">
            <TextBlock Text="🎓 Apprentice Manager"
                       Foreground="White" FontSize="20" FontWeight="Bold"/>
        </Border>

        <TabControl Grid.Row="1" Margin="5">
            <TabItem Header="Lernende" FontSize="13" Padding="10,4">
                <controls:ApprenticesControl x:Name="ApprenticesTab"/>
            </TabItem>
            <TabItem Header="Noten" FontSize="13" Padding="10,4">
                <controls:GradesControl x:Name="GradesTab"/>
            </TabItem>
            <TabItem Header="Lernjournal" FontSize="13" Padding="10,4">
                <controls:LearningJournalControl x:Name="JournalTab"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
