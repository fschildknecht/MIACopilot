<UserControl x:Class="ApprenticeManager.UI.App.Controls.ApprenticesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="ApprenticesGrid" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single"
                  CanUserAddRows="False" Margin="5,5,5,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45"/>
                <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Geburtsdatum" Width="110">
                    <DataGridTextColumn.Binding>
                        <Binding Path="DateOfBirth" StringFormat="dd.MM.yyyy"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Beruf" Binding="{Binding Occupation}" Width="*"/>
                <DataGridTextColumn Header="Betrieb" Binding="{Binding Company}" Width="*"/>
                <DataGridTextColumn Header="Lehrstart" Width="90">
                    <DataGridTextColumn.Binding>
                        <Binding Path="StartDate" StringFormat="dd.MM.yyyy"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Lehrende" Width="90">
                    <DataGridTextColumn.Binding>
                        <Binding Path="EndDate" StringFormat="dd.MM.yyyy"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="E-Mail" Binding="{Binding Email}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
            <Button Content="Hinzufügen" Padding="10,5" Margin="0,0,5,0" Click="AddButton_Click"/>
            <Button Content="Bearbeiten" Padding="10,5" Margin="0,0,5,0" Click="EditButton_Click"/>
            <Button Content="Löschen" Padding="10,5" Margin="0,0,5,0" Click="DeleteButton_Click"/>
            <Button Content="Aktualisieren" Padding="10,5" Click="RefreshButton_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
