<UserControl x:Class="ApprenticeManager.UI.App.Controls.GradesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Lernender Auswahl -->
        <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
            <TextBlock Text="Lernender:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
            <ComboBox x:Name="ApprenticeComboBox" Width="220" DisplayMemberPath="FullName"
                      SelectionChanged="ApprenticeComboBox_SelectionChanged"/>
        </StackPanel>

        <!-- Fächer -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Fächer" FontWeight="Bold" Margin="5,3,0,2"/>
            <DataGrid x:Name="SubjectsGrid" Grid.Row="1" AutoGenerateColumns="False"
                      IsReadOnly="True" SelectionMode="Single" CanUserAddRows="False"
                      Margin="5,0,5,0" SelectionChanged="SubjectsGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Fach" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Durchschnittsnote" Width="140">
                        <DataGridTextColumn.Binding>
                            <Binding Path="AverageGrade" StringFormat="F2"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Anzahl Noten" Binding="{Binding Grades.Count}" Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5,3">
                <Button Content="Fach hinzufügen" Padding="10,5" Margin="0,0,5,0" Click="AddSubjectButton_Click"/>
                <Button Content="Fach löschen" Padding="10,5" Click="DeleteSubjectButton_Click"/>
            </StackPanel>
        </Grid>

        <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch" Background="LightGray"/>

        <!-- Noten für gewähltes Fach -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="GradesHeader" Text="Noten" FontWeight="Bold" Margin="5,3,0,2"/>
            <DataGrid x:Name="GradesGrid" Grid.Row="1" AutoGenerateColumns="False"
                      IsReadOnly="True" SelectionMode="Single" CanUserAddRows="False"
                      Margin="5,0,5,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Note" Width="80">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Value" StringFormat="F1"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Datum" Width="100">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Date" StringFormat="dd.MM.yyyy"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Bemerkungen" Binding="{Binding Notes}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5,3">
                <Button Content="Note hinzufügen" Padding="10,5" Margin="0,0,5,0" Click="AddGradeButton_Click"/>
                <Button Content="Note löschen" Padding="10,5" Click="DeleteGradeButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
