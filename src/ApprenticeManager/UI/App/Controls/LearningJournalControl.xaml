<UserControl x:Class="ApprenticeManager.UI.App.Controls.LearningJournalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Background="#f0f4f8" BorderBrush="#d0d8e4" BorderThickness="0,0,0,1" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Lernender Auswahl (nur im Lehrlingsbetreuer-Modus sichtbar) -->
                <StackPanel x:Name="ApprenticeSelector" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Lernender:" VerticalAlignment="Center" Margin="0,0,8,0"
                               FontWeight="SemiBold" Foreground="#1e3a5f"/>
                    <ComboBox x:Name="ApprenticeComboBox" Width="220" DisplayMemberPath="FullName"
                              SelectionChanged="ApprenticeComboBox_SelectionChanged"/>
                </StackPanel>

                <!-- Aktionsbuttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="+ Neuer Eintrag" Padding="10,5" Margin="0,0,5,0" Click="AddButton_Click"/>
                    <Button Content="✎ Bearbeiten" Padding="10,5" Margin="0,0,5,0" Click="EditButton_Click"/>
                    <Button Content="✕ Löschen" Padding="10,5" Margin="0,0,5,0" Click="DeleteButton_Click"/>
                    <Button Content="↻ Aktualisieren" Padding="10,5" Click="RefreshButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Master-Detail Layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" MinWidth="150"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Eintrags-Liste (links) -->
            <Border BorderBrush="#d0d8e4" BorderThickness="0,0,1,0">
                <ListBox x:Name="JournalList" SelectionChanged="JournalList_SelectionChanged"
                         BorderThickness="0" Background="White">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" BorderBrush="#eee" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="{Binding Titel}" FontWeight="Bold"
                                               FontSize="13" Foreground="#1e3a5f"/>
                                    <TextBlock Text="{Binding ErstelltAm, StringFormat='Erstellt: dd.MM.yyyy'}"
                                               Foreground="#777" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#d0d8e4"/>

            <!-- Detail-Panel (rechts) -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <!-- Hinweis wenn kein Eintrag gewählt -->
                    <TextBlock x:Name="EmptyHint"
                               Text="← Journaleintrag auswählen, um den Inhalt anzuzeigen."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#aaa" FontSize="14" FontStyle="Italic"
                               Margin="20"/>

                    <!-- Detailansicht -->
                    <StackPanel x:Name="DetailPanel" Margin="20" Visibility="Collapsed">
                        <TextBlock x:Name="DetailTitle" FontSize="20" FontWeight="Bold"
                                   Foreground="#1e3a5f" Margin="0,0,0,4"/>
                        <TextBlock x:Name="DetailMeta" Foreground="#777" FontSize="11" Margin="0,0,0,18"/>

                        <TextBlock Text="Betriebliche Tätigkeiten" FontWeight="Bold"
                                   Foreground="#1e3a5f" FontSize="13" Margin="0,0,0,5"/>
                        <Border Background="#f8f9fa" BorderBrush="#dee2e6" BorderThickness="1"
                                CornerRadius="4" Padding="12" Margin="0,0,0,16">
                            <TextBlock x:Name="DetailBetrieb" TextWrapping="Wrap" LineHeight="22" FontSize="13"/>
                        </Border>

                        <TextBlock Text="Schulische Tätigkeiten" FontWeight="Bold"
                                   Foreground="#1e3a5f" FontSize="13" Margin="0,0,0,5"/>
                        <Border Background="#f8f9fa" BorderBrush="#dee2e6" BorderThickness="1"
                                CornerRadius="4" Padding="12" Margin="0,0,0,16">
                            <TextBlock x:Name="DetailSchule" TextWrapping="Wrap" LineHeight="22" FontSize="13"/>
                        </Border>

                        <TextBlock Text="Reflexion" FontWeight="Bold"
                                   Foreground="#1e3a5f" FontSize="13" Margin="0,0,0,5"/>
                        <Border Background="#f8f9fa" BorderBrush="#dee2e6" BorderThickness="1"
                                CornerRadius="4" Padding="12" Margin="0,0,0,16">
                            <TextBlock x:Name="DetailReflexion" TextWrapping="Wrap" LineHeight="22" FontSize="13"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
