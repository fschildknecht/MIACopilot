<UserControl x:Class="ApprenticeManager.UI.App.Controls.LearningJournalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Lernender Auswahl -->
        <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
            <TextBlock Text="Lernender:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
            <ComboBox x:Name="ApprenticeComboBox" Width="220" DisplayMemberPath="FullName"
                      SelectionChanged="ApprenticeComboBox_SelectionChanged"/>
        </StackPanel>

        <!-- Journaleinträge -->
        <DataGrid x:Name="JournalGrid" Grid.Row="1" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single" CanUserAddRows="False"
                  Margin="5,0,5,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="KW/Jahr" Binding="{Binding Titel}" Width="90"/>
                <DataGridTextColumn Header="Betriebliche Tätigkeiten" Binding="{Binding BetrieblicheTaetigkeiten}" Width="*"/>
                <DataGridTextColumn Header="Schulische Tätigkeiten" Binding="{Binding SchulischeTaetigkeiten}" Width="*"/>
                <DataGridTextColumn Header="Reflexion" Binding="{Binding Reflexion}" Width="*"/>
                <DataGridTextColumn Header="Erstellt" Width="100">
                    <DataGridTextColumn.Binding>
                        <Binding Path="ErstelltAm" StringFormat="dd.MM.yyyy"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Geändert" Width="100">
                    <DataGridTextColumn.Binding>
                        <Binding Path="GeaendertAm" StringFormat="dd.MM.yyyy"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5">
            <Button Content="Neuer Eintrag" Padding="10,5" Margin="0,0,5,0" Click="AddButton_Click"/>
            <Button Content="Bearbeiten" Padding="10,5" Margin="0,0,5,0" Click="EditButton_Click"/>
            <Button Content="Löschen" Padding="10,5" Margin="0,0,5,0" Click="DeleteButton_Click"/>
            <Button Content="Aktualisieren" Padding="10,5" Click="RefreshButton_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
